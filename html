                            </div>
                            <span class="error-msg" id="nameError">Nama lengkap wajib diisi</span>
                        </div>
                        
                        <!-- Nomor Telepon Input -->
                        <div class="form-group">
                            <div class="input-wrapper">
                                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
