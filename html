                                </svg>
                                <input type="url" id="storeLink" placeholder="Link Toko (Shopee / Tokopedia / dll)" required>
                            </div>
                            <span class="error-msg" id="storeLinkError">Masukkan link toko yang valid (contoh: https://shopee.co.id/toko-anda)</span>
